# Copy to .env and fill in. Never commit the real .env.
# On Railway: set these in your web service's "Variables" tab.

# ── REQUIRED: LLM + indexing API keys ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TWELVELABS_API_KEY=

# ── Login (CHANGE the password + secret for anything public) ──
TREELZ_USER=dfine
TREELZ_PASSWORD=cool123
TREELZ_SECRET=change-me-to-a-long-random-string

# ── Caption model provider: "anthropic" | "openai" ──
CAPTION_PROVIDER=anthropic

# ── Validated-reel export folder (on the volume by default; point at a synced folder later) ──
REEL_EXPORT_DIR=var/validated

# ── Database — Railway sets this when you add the Postgres plugin ──
# (on the web service, add: DATABASE_URL = ${{Postgres.DATABASE_URL}} )
DATABASE_URL=

# ── OPTIONAL: Cloudflare R2 (leave blank to use the volume only) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=trial-studio
R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com

# ── OPTIONAL: Redis (only if you run the separate async indexing worker) ──
REDIS_URL=

# ── Google Drive INGEST (service account, read-only; creators share folders with the SA email) ──
GOOGLE_SA_JSON=            # raw key JSON contents (Railway) …
GOOGLE_SA_JSON_FILE=       # … or a local path to the key file (local dev)

# ── Google Drive EXPORT (OAuth as the operator; drive.file scope; consent app must stay Published) ──
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ── Knobs (defaults in app/config.py) ──
INDEX_CONCURRENCY=6        # clips in flight (TL processes ~3 concurrently; 6 keeps it saturated)
SYNC_MAX_CLIP_SECONDS=20   # Drive sync skips longer clips (0 = no cap)
CLIP_SIM_THRESHOLD=0.93    # within-reel visual de-dup (embedding cosine)
DRIVE_EXPORT_ROOT=treelz exports
